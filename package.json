{
  "name": "cloudflare-subdomain-provisioning",
  "version": "1.0.0",
  "description": "Cloudflare Workers 二级域名分发服务",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute subdomain-db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute subdomain-db --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.90.0"
  }
}
